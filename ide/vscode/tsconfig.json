{
  // Base TypeScript configuration for the extension.
  //
  // The extension itself is bundled by esbuild (see esbuild.js), so this config is used
  // mainly for editor IntelliSense and for the `tsc --noEmit` type-check that runs as part
  // of `npm run compile`. The separate tsconfig.test.json turns on emit to produce runnable
  // JavaScript for the test suites.
  "compilerOptions": {
    // VSCode 1.120 ships a modern Node/Electron runtime, so we can target a recent ES level.
    "target": "ES2022",
    "lib": ["ES2022"],
    // The VSCode extension host loads CommonJS modules.
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": "src",
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "skipLibCheck": true,
    // We only type-check here; esbuild produces the shipped bundle.
    "noEmit": true
  },
  "include": ["src"]
}
